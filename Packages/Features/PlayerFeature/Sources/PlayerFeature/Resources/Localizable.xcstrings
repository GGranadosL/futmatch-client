{
  "sourceLanguage" : "en",
  "strings" : {
    "%@ - %@" : {
      "comment" : "A text label displaying the date and time of a hockey match. The first argument is the date of the match. The second argument is the time range of the match.",
      "isCommentAutoGenerated" : true,
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "%1$@ - %2$@"
          }
        }
      }
    },
    "%lld" : {
      "comment" : "A number that is displayed in a card.",
      "isCommentAutoGenerated" : true
    },
    "%lld - %lld" : {
      "comment" : "A score display for a game. The first argument is the score of the home team. The second argument is the score of the away team.",
      "isCommentAutoGenerated" : true,
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "%1$lld - %2$lld"
          }
        }
      }
    },
    "•" : {
      "comment" : "A bullet point symbol used in a list.",
      "isCommentAutoGenerated" : true
    },
    "99+" : {
      "comment" : "A number that is appended to a bell icon to show the number of unread notifications.",
      "isCommentAutoGenerated" : true
    },
    "Cancelado" : {
      "comment" : "A label for a match that has been canceled.",
      "isCommentAutoGenerated" : true
    },
